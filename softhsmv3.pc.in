prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: @PACKAGE_NAME@
Description: PKCS#11 v3.2 software HSM with ML-KEM, ML-DSA, and SLH-DSA support
Version: @VERSION@
URL: @PACKAGE_URL@
Libs: -L${libdir}/softhsm -l@PROJECT_NAME@
Cflags: -I${includedir}/softhsm
