prefix=/usr/local
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: SoftHSMv3
Description: PKCS#11 v3.2 software HSM with ML-KEM, ML-DSA, and SLH-DSA support
Version: 3.0.0
URL: https://github.com/pqctoday/softhsmv3
Libs: -L${libdir}/softhsm -lsofthsmv3
Cflags: -I${includedir}/softhsm
