+		case KEY_ML_DSA_65:
+			return OID_ML_DSA_65;
+		case KEY_ML_DSA_87:
+			return OID_ML_DSA_87;
+		case KEY_ECDSA:
+			return OID_EC_PUBLICKEY;
+		default:
+			return OID_UNKNOWN;
+	}
+}
