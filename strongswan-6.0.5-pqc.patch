+		case OID_ED448:
+			return KEY_ED448;
+		case OID_ML_DSA_44:
+			return KEY_ML_DSA_44;
+		case OID_ML_DSA_65:
+			return KEY_ML_DSA_65;
+		case OID_ML_DSA_87:
+			return KEY_ML_DSA_87;
+		case OID_EC_PUBLICKEY:
+			return KEY_ECDSA;
+		case OID_RSA_ENCRYPTION:
+		case OID_RSAES_OAEP:
+		case OID_RSASSA_PSS:
+			return KEY_RSA;
+		default:
+			return KEY_ANY;
+	}
+}
