# strongSwan 6.0.5 PQC Core Patch
# Subset of strongswan/strongswan#2626 (ML-DSA FIPS 204) — minimal core changes only.
# PKCS#11 plugin changes handled separately via `cp -r pqctoday-hsm/strongswan-pkcs11/` in build script.
# Native ml_dsa plugin and non-pkcs11 backends intentionally excluded.
#
# Included files (relative to strongSwan source tree root):
#   src/libstrongswan/asn1/asn1.c                              (ML-DSA OIDs in algorithmIdentifier)
#   src/libstrongswan/asn1/oid.txt                             (new ML-DSA OID leaves)
#   src/libstrongswan/credentials/auth_cfg.c                   (ML-DSA key tokens + schemes)
#   src/libstrongswan/credentials/cred_encoding.h              (CRED_PART_PUB/PRIV_ASN1_DER)
#   src/libstrongswan/credentials/keys/public_key.c            (key_type enum names, info_encode/decode, helpers)
#   src/libstrongswan/credentials/keys/public_key.h            (KEY_ML_DSA_*, SIGN_ML_DSA_*, new API)
#   src/libstrongswan/credentials/keys/signature_params.c      (pqc_params_create/free)
#   src/libstrongswan/credentials/keys/signature_params.h      (pqc_params_t)
#   src/libstrongswan/crypto/hashers/hasher.c                  (ML-DSA identity hash mapping)
#   src/libstrongswan/plugins/pem/pem_encoder.c                (CRED_PART_PUB/PRIV_ASN1_DER paths)
#   src/libstrongswan/plugins/pem/pem_plugin.c                 (ML-DSA PEM pub/priv registrations)
#   src/libstrongswan/plugins/pkcs1/pkcs1_builder.c            (refactored parse_public_key via new helper)
#   src/libstrongswan/plugins/pkcs1/pkcs1_plugin.c             (ML-DSA PUBKEY soft-deps)
#   src/libstrongswan/plugins/pkcs8/pkcs8_builder.c            (ML-DSA OID → key type mapping)
#   src/libstrongswan/plugins/pkcs8/pkcs8_plugin.c             (ML-DSA PRIVKEY providers)
#
